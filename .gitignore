(
echo # Only code files
echo *
echo !*/
echo !*.py
echo !*.ipynb
echo !.gitignore
echo.
echo # Always ignore data
echo features/
echo results/
echo *.npy
echo *.wav
echo __pycache__/
echo.
echo # Jupyter
echo .ipynb_checkpoints/
echo *.ipynb_checkpoints
echo.
echo # Temporary files
echo Untitled*.py
echo Untitled*.ipynb
) > .gitignore
